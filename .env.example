# Copy to .env and fill in real values. Never commit .env.

# Supabase (web platform only — required for web dev/build)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key (contact form captcha widget)
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=

# PostHog product analytics (optional — analytics no-ops if unset)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# Google Analytics (optional)
VITE_G_ANALYTICS_ID=

# Desktop release signing (only needed for `npm run tauri build` release builds)
# See llm-instructions/deployment/setup-updater-keys.md
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
